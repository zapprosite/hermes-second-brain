# hermes-second-brain environment variables template
#
# This is a template file for documentation purposes.
# The canonical .env file for this service is located at:
#   /srv/monorepo/.env
#
# Copy this file to .env and fill in the values as needed.
# DO NOT commit actual secrets to version control.

# Mem0 Configuration
MEM0_BACKEND=qdrant
MEM0_QDRANT_URL=http://localhost:6333
MEM0_QDRANT_COLLECTION=will
MEM0_OLLAMA_URL=http://localhost:11434
MEM0_OLLAMA_MODEL=qwen2.5:3b
MEM0_TASKS_DB_PATH=/srv/data/librarian/tasks.db

# Qdrant Configuration
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=${QDRANT_API_KEY}
QDRANT_GRPC_URL=localhost:6334
